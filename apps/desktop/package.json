{
  "name": "@arkitect/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/free-dev-port.mjs",
    "dev": "concurrently -k \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"vite\" \"wait-on http-get://127.0.0.1:5173 file:dist-electron/main.js file:dist-electron/preload.js && cross-env ARKITECT_RENDERER_URL=http://127.0.0.1:5173 NODE_OPTIONS=--use-system-ca electron dist-electron/main.js\"",
    "start": "cross-env NODE_OPTIONS=--use-system-ca electron dist-electron/main.js",
    "build": "tsc -p tsconfig.electron.json && tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@arkitect/ai": "workspace:*",
    "@arkitect/contracts": "workspace:*",
    "@arkitect/core": "workspace:*",
    "@arkitect/design-system": "workspace:*",
    "@arkitect/github": "workspace:*",
    "@arkitect/mcp-server": "workspace:*",
    "@arkitect/repo-analyzer": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@cursor/sdk": "^1.0.18",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
