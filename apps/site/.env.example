# Dedicated Arkitect Supabase project (safe, publishable values only).
# Copy this file to .env.local and fill in real values to enable live data.
# Without these, the site runs on local in-memory mock data automatically.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Public download link shown after a visitor claims a free spot (GitHub release asset URL).
# Example: https://github.com/ezequielcasillas1/Arkitect-MCP.AI/releases/download/v0.1.1/Arkitect-Setup.exe
VITE_DOWNLOAD_URL=
