{
  "name": "@arkitect/ai",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@arkitect/contracts": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"**/*.integration.test.ts\" --exclude \"tests/**\"",
    "test:integration": "vitest run --passWithNoTests --include \"**/*.integration.test.ts\" --include \"tests/**/*.test.ts\""
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
