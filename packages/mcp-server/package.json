{
  "name": "@arkitect/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "arkitect-mcp": "./dist/stdio.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "default": "./dist/browser.js"
    }
  },
  "dependencies": {
    "@arkitect/contracts": "workspace:*",
    "@arkitect/core": "workspace:*",
    "@arkitect/repo-analyzer": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:integration": "vitest run tests --passWithNoTests"
  }
}
