{
  "name": "arkitect",
  "private": true,
  "version": "0.1.0",
  "description": "Arkitect monorepo foundation scaffold.",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:desktop": "pnpm --filter @arkitect/desktop dev",
    "start:desktop": "pnpm --filter @arkitect/desktop start",
    "dev:site": "pnpm --filter @arkitect/site dev",
    "dev:worker": "pnpm --filter @arkitect/licensing-worker dev",
    "verify": "pnpm lint && pnpm build && pnpm typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "pnpm": "^11.6.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
